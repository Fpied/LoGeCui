<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lang="clr-namespace:LoGeCuiMobile.Resources.Lang"
             xmlns:tr="clr-namespace:LoGeCuiMobile.Resources.Lang"
             x:Class="LoGeCuiMobile.Pages.LoginPage"
             Title="LoGeCui - Connexion"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            

            <!-- Logo -->
            <Label Text="🛒 LoGeCui"
                   FontSize="42"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   Margin="0,10,0,30"/>

            <!-- 🌍 Choix de langue -->
            <Picker x:Name="LanguagePicker"
        Title="🌍 Language"
        SelectedIndexChanged="LanguagePicker_SelectedIndexChanged">
                <Picker.Items>
                    <x:String>🇫🇷 Français</x:String>
                    <x:String>🇬🇧 English</x:String>
                    <x:String>🇩🇪 Deutsch</x:String>
                    <x:String>🇪🇸 Español</x:String>
                    <x:String>🇮🇹 Italiano</x:String>
                    <x:String>🇸🇦 العربية</x:String>
                    <x:String>🇵🇱 Polski</x:String>
                    <x:String>🇹🇷 Türkçe</x:String>
                    <x:String>🇷🇴 Română</x:String>
                    <x:String>🇨🇿 Čeština</x:String>
                    <x:String>🇰🇷 한국어</x:String>
                    <x:String>🇯🇵 日本語</x:String>
                    <x:String>🇹🇭 ไทย</x:String>
                    <x:String>🇮🇳 हिन्दी</x:String>
                    <x:String>🇨🇳 中文</x:String>
                    <x:String>🇧🇬 Български</x:String>
                    <x:String>🇩🇰 Dansk</x:String>
                    <x:String>🇬🇷 Ελληνικά</x:String>
                    <x:String>🇪🇪 Eesti</x:String>
                    <x:String>🇫🇮 Suomi</x:String>
                    <x:String>🇭🇺 Magyar</x:String>
                    <x:String>🇮🇩 Indonesia</x:String>
                    <x:String>🇱🇹 Lietuvių</x:String>
                    <x:String>🇱🇻 Latviešu</x:String>
                    <x:String>🇳🇴 Norsk</x:String>
                    <x:String>🇳🇱 Nederlands</x:String>
                    <x:String>🇧🇷 Português (BR)</x:String>
                    <x:String>🇵🇹 Português (PT)</x:String>
                    <x:String>🇷🇺 Русский</x:String>
                    <x:String>🇸🇰 Slovenčina</x:String>
                    <x:String>🇸🇮 Slovenščina</x:String>
                    <x:String>🇸🇪 Svenska</x:String>
                    <x:String>🇺🇦 Українська</x:String>
                    <x:String>🇹🇼 繁體中文</x:String>
                </Picker.Items>
            </Picker>

            <!-- Email -->
            <Label Text="{tr:Translate Email}"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Entry x:Name="TxtEmail"
                   Placeholder="email@example.com"
                   Keyboard="Email"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- Mot de passe -->
            <Label Text="{tr:Translate Password}"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Grid ColumnDefinitions="*,Auto"
                  BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                  Padding="8">

                <Entry x:Name="TxtPassword"
                       Placeholder="••••••••"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <Button Grid.Column="1"
                        Text="👁"
                        BackgroundColor="Transparent"
                        Clicked="TogglePassword"/>
            </Grid>

            <!-- Rester connecté -->
            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="ChkRememberMe" Color="#27AE60"/>
                <Label Text="{tr:Translate StayConnected}"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
            </HorizontalStackLayout>

            <!-- Connexion -->
            <Button x:Name="BtnConnexion"
                    Text="{tr:Translate LoginButton}"
                    BackgroundColor="#27AE60"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="10"
                    Clicked="BtnConnexion_Clicked"/>

            <!-- Inscription -->
            <Button x:Name="BtnInscription"
                    Text="{tr:Translate SignupButton}"
                    BackgroundColor="#3498DB"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="10"
                    Clicked="BtnInscription_Clicked"/>

            <!-- Message -->
            <Label x:Name="TxtMessage"
                   TextColor="Red"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Mot de passe oublié -->
            <Button Text="{tr:Translate ForgotPassword}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Blue, Dark=#4DA3FF}"
                    Clicked="BtnForgotPassword_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
